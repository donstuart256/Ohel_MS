# ============================================================
# .env.example — Copy to .env and fill in real values.
# DO NOT put real credentials in this file.
# ============================================================

# Django core
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=CHANGEME_generate_a_strong_secret_key

# Set to True ONLY for local development. Must be False in production.
DEBUG=False

# Comma-separated list of valid host headers (e.g. localhost,myschool.ug)
ALLOWED_HOSTS=localhost

# Comma-separated allowed CORS origins (e.g. https://app.myschool.ug)
CORS_ALLOWED_ORIGINS=http://localhost:3000

# JWT signing key (use a different secret from SECRET_KEY)
# Generate with: python -c "import secrets; print(secrets.token_hex(64))"
JWT_SIGNING_KEY=CHANGEME_generate_a_strong_jwt_signing_key

# ============================================================
# Database (PostgreSQL)
# ============================================================
POSTGRES_DB=uganda_sms
POSTGRES_USER=CHANGEME_db_user
POSTGRES_PASSWORD=CHANGEME_strong_db_password
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgres://CHANGEME_db_user:CHANGEME_strong_db_password@db:5432/uganda_sms

# ============================================================
# Redis
# ============================================================
REDIS_URL=redis://redis:6379/0

# ============================================================
# Third-party API keys
# ============================================================
TESTSPRITE_API_KEY=CHANGEME_your_testsprite_api_key
